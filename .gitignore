# ============================================
# Data Files (Large files should not be committed)
# ============================================
# Raw data files (usually large)
data/raw/*.csv
data/raw/*.json
data/raw/*.txt
data/raw/*.xlsx
data/raw/*.xls
data/raw/*.parquet

# Processed data files (generated, can be recreated)
data/processed/*.csv
data/processed/*.json
data/processed/*.parquet

# Exception: Keep sample/small data files for demos
!data/sample/
!data/sample/*.csv

# Temporary data files
data/temp/
data/tmp/

# ============================================
# Model Files (Can be large)
# ============================================
# Trained models (usually too large for git)
models/*.pkl
models/*.joblib
models/*.h5
models/*.pt
models/*.pth
models/*.ckpt
models/*.pb

# Model checkpoints
models/checkpoints/

# Exception: Keep small example models or metadata
!models/model_metadata.json
!models/README.md

# ============================================
# Results & Outputs
# ============================================
# Generated figures/plots
results/figures/*.png
results/figures/*.jpg
results/figures/*.pdf

# Logs
logs/
*.log

# Temporary results
results/temp/
results/tmp/

# ============================================
# Notebooks (Optional - read notes below)
# ============================================
# Notebook outputs (some teams clear outputs before committing)
# Uncomment if you want to clear outputs:
# **/.ipynb_checkpoints/
# *.ipynb

# Note: Most people DO commit notebooks WITH outputs for documentation
# Only uncomment above if your team policy requires clean notebooks

